#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CLAUDE_DIR="$REPO_DIR/claude"
OUT_ROOT="$REPO_DIR/codex/generated"
OUT_SKILLS="$OUT_ROOT/skills"
OUT_PLUGINS="$OUT_ROOT/plugins"
OUT_AGENTS="$OUT_ROOT/agents"
MAP_FILE="$OUT_ROOT/MAPPING.md"

slugify() {
  echo "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//'
}

extract_meta() {
  local key="$1"
  local file="$2"
  awk -v wanted="$key" '
    NR == 1 && $0 == "---" { in_fm = 1; next }
    in_fm && $0 == "---" { exit }
    in_fm && $1 == wanted ":" {
      sub("^[^:]+:[[:space:]]*", "", $0)
      print
      exit
    }
  ' "$file"
}

strip_frontmatter() {
  local file="$1"
  awk '
    NR == 1 && $0 == "---" { in_fm = 1; next }
    in_fm && $0 == "---" { in_fm = 0; next }
    !in_fm { print }
  ' "$file"
}

write_skill() {
  local source_file="$1"
  local target_slug="$2"
  local display_name="$3"
  local description="$4"
  local rel_source

  rel_source="${source_file#"$REPO_DIR/"}"
  mkdir -p "$OUT_SKILLS/$target_slug"

  {
    echo "---"
    echo "name: $display_name"
    if [ -n "$description" ]; then
      echo "description: $description"
    else
      echo "description: Generated from $rel_source"
    fi
    echo "---"
    echo
    echo "Generated from \`$rel_source\` by \`bin/sync-codex-from-claude\`."
    echo
    strip_frontmatter "$source_file"
  } > "$OUT_SKILLS/$target_slug/SKILL.md"

  echo "- \`$rel_source\` -> \`codex/generated/skills/$target_slug/SKILL.md\`" >> "$MAP_FILE"
}

mkdir -p "$OUT_ROOT"
rm -rf "$OUT_SKILLS" "$OUT_PLUGINS" "$OUT_AGENTS"
mkdir -p "$OUT_SKILLS" "$OUT_PLUGINS" "$OUT_AGENTS"

cat > "$MAP_FILE" <<'EOF'
# Claude -> Codex Mapping

This directory is generated by `bin/sync-codex-from-claude`.
Do not edit generated files by hand.

## Skills

EOF

# Translate top-level Claude skills.
for source in "$CLAUDE_DIR/skills"/*/SKILL.md; do
  [ -f "$source" ] || continue
  raw_name="$(extract_meta name "$source")"
  raw_desc="$(extract_meta description "$source")"
  skill_name="${raw_name:-$(basename "$(dirname "$source")")}"
  skill_slug="$(slugify "$skill_name")"
  write_skill "$source" "$skill_slug" "$skill_name" "$raw_desc"
done

# Translate plugin skills (flattened to namespaced Codex skill names).
for source in "$CLAUDE_DIR/plugins"/*/skills/*/SKILL.md; do
  [ -f "$source" ] || continue
  plugin_name="$(basename "$(dirname "$(dirname "$(dirname "$source")")")")"
  local_name="$(basename "$(dirname "$source")")"
  raw_name="$(extract_meta name "$source")"
  raw_desc="$(extract_meta description "$source")"
  skill_name="${raw_name:-$plugin_name:$local_name}"
  skill_slug="$(slugify "${plugin_name}-${local_name}")"
  write_skill "$source" "$skill_slug" "$skill_name" "$raw_desc"
done

cat >> "$MAP_FILE" <<'EOF'

## Agents

EOF

# Translate top-level Claude agents (verbatim — Codex reads the same YAML frontmatter format).
for agent_file in "$CLAUDE_DIR/agents"/*.md; do
  [ -f "$agent_file" ] || continue
  agent_name="$(basename "$agent_file")"
  rel_source="${agent_file#"$REPO_DIR/"}"
  cp "$agent_file" "$OUT_AGENTS/$agent_name"
  echo "- \`$rel_source\` -> \`codex/generated/agents/$agent_name\`" >> "$MAP_FILE"
done

cat >> "$MAP_FILE" <<'EOF'

## Plugins

EOF

# Translate plugin manifests into Codex plugin layout.
for plugin_manifest in "$CLAUDE_DIR/plugins"/*/.claude-plugin/plugin.json; do
  [ -f "$plugin_manifest" ] || continue
  plugin_dir="$(dirname "$(dirname "$plugin_manifest")")"
  plugin_name="$(basename "$plugin_dir")"
  out_plugin="$OUT_PLUGINS/$plugin_name"
  rel_source="${plugin_manifest#"$REPO_DIR/"}"

  mkdir -p "$out_plugin/.codex-plugin"
  cp "$plugin_manifest" "$out_plugin/.codex-plugin/plugin.json"

  if [ -d "$plugin_dir/skills" ]; then
    cp -R "$plugin_dir/skills" "$out_plugin/skills"
  fi
  if [ -d "$plugin_dir/agents" ]; then
    cp -R "$plugin_dir/agents" "$out_plugin/agents"
  fi
  if [ -d "$plugin_dir/bin" ]; then
    cp -R "$plugin_dir/bin" "$out_plugin/bin"
  fi
  if [ -d "$plugin_dir/seed" ]; then
    cp -R "$plugin_dir/seed" "$out_plugin/seed"
  fi

  echo "- \`$rel_source\` -> \`codex/generated/plugins/$plugin_name/.codex-plugin/plugin.json\`" >> "$MAP_FILE"
done

# Translate the Claude marketplace manifest into the Codex location so
# `codex plugin marketplace add codex/generated/plugins` registers it.
claude_marketplace="$CLAUDE_DIR/plugins/.claude-plugin/marketplace.json"
if [ -f "$claude_marketplace" ]; then
  mkdir -p "$OUT_PLUGINS/.agents/plugins"
  cp "$claude_marketplace" "$OUT_PLUGINS/.agents/plugins/marketplace.json"
  rel_source="${claude_marketplace#"$REPO_DIR/"}"
  echo "- \`$rel_source\` -> \`codex/generated/plugins/.agents/plugins/marketplace.json\`" >> "$MAP_FILE"
fi

echo "Synced Claude assets into codex/generated"
