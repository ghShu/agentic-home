# Jira plugin configuration.
#
# Copy this file to ~/.jira.env and fill in your values. The jira plugin reads
# these as environment variables first, falling back to ~/.jira.env if unset.
# Override the file path with $JIRA_ENV_FILE.

# Required — Atlassian Cloud tenant URL.
JIRA_HOST="https://your-tenant.atlassian.net"

# Default project key used by `jira:create` when --project is not supplied.
JIRA_PROJECT_KEY="PROJ"

# Optional — path to a JSON file mapping Jira custom-field IDs to display names.
# The mapping is tenant-specific; discover IDs by inspecting an issue payload
# (`jira_cmd jira PROJ-1234` and look at the raw API response).
#
# Example file contents:
#   {
#     "customfield_10082": "case_url",
#     "customfield_10185": "firm_name",
#     "customfield_10187": "incident_date"
#   }
#
# JIRA_CUSTOM_FIELDS_FILE="~/.jira-custom-fields.json"
